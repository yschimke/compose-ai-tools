# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# IDE
.idea/
*.iml
*.ipr
*.iws
.vscode/
# Eclipse-style compile output (IntelliJ writes this when "Use Build and run
# using: IDE" is selected; Gradle puts its output in build/ instead).
bin/

# Kotlin
.kotlin/

# Java
*.class
hs_err_pid*
replay_pid*

# OS
.DS_Store
Thumbs.db

# AI
# Ignore local .claude/ scratch (sessions, projects, shell-snapshots, etc.)
# but track the shared SessionStart hook + settings so every clone gets the
# same agent setup wiring.
.claude/*
!.claude/hooks/
!.claude/settings.json
.claude/hooks/*
!.claude/hooks/*.sh
.gemini/

# Local properties
local.properties

# Node / VS Code extension
node_modules/
vscode-extension/out/
*.vsix

# Python (for .github/actions/lib/ scripts and their tests)
__pycache__/
*.pyc
