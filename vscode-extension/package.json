{
    "name": "compose-preview",
    "displayName": "Compose Preview",
    "description": "Live preview rendering for Jetpack Compose and Compose Multiplatform @Preview functions",
    "version": "0.1.0",
    "publisher": "yuri-schimke",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/yschimke/compose-ai-tools.git",
        "directory": "vscode-extension"
    },
    "bugs": {
        "url": "https://github.com/yschimke/compose-ai-tools/issues"
    },
    "homepage": "https://github.com/yschimke/compose-ai-tools#readme",
    "engines": {
        "vscode": "^1.85.0"
    },
    "icon": "media/icon.png",
    "galleryBanner": {
        "color": "#1B1B1F",
        "theme": "dark"
    },
    "categories": [
        "Visualization"
    ],
    "keywords": [
        "compose",
        "jetpack-compose",
        "compose-multiplatform",
        "android",
        "preview",
        "kotlin"
    ],
    "activationEvents": [
        "onLanguage:kotlin",
        "workspaceContains:**/build.gradle.kts"
    ],
    "extensionDependencies": [
        "vscjava.vscode-gradle"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "compose-preview",
                    "title": "Compose Preview",
                    "icon": "media/preview-icon.svg"
                }
            ]
        },
        "views": {
            "compose-preview": [
                {
                    "type": "webview",
                    "id": "composePreview.panel",
                    "name": "Previews"
                }
            ]
        },
        "commands": [
            {
                "command": "composePreview.refresh",
                "title": "Refresh Previews",
                "category": "Compose Preview",
                "icon": "$(refresh)"
            },
            {
                "command": "composePreview.renderAll",
                "title": "Render All Previews",
                "category": "Compose Preview"
            },
            {
                "command": "composePreview.openModuleBuildFile",
                "title": "Open Module build.gradle.kts",
                "category": "Compose Preview"
            },
            {
                "command": "composePreview.toggleAccessibilityChecks",
                "title": "Toggle Accessibility Checks",
                "category": "Compose Preview"
            },
            {
                "command": "composePreview.runDoctor",
                "title": "Run Doctor (refresh compatibility diagnostics)",
                "category": "Compose Preview"
            }
        ],
        "configuration": {
            "title": "Compose Preview",
            "properties": {
                "composePreview.variant": {
                    "type": "string",
                    "default": "debug",
                    "description": "Build variant to use for preview rendering"
                },
                "composePreview.accessibilityChecks.enabled": {
                    "type": "boolean",
                    "default": false,
                    "description": "Run ATF accessibility checks on every rendered preview. When on, the extension passes `-PcomposePreview.accessibilityChecks.enabled=true` to each Gradle task; findings surface as diagnostics in the Problems panel and on the `@Preview` line. Overrides the `accessibilityChecks { enabled = ... }` block in build.gradle.kts for this session only."
                }
            }
        }
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "test": "npm run compile && mocha 'out/test/!(electron)/**/*.test.js' 'out/test/*.test.js'",
        "test:electron": "npm run compile && node ./out/test/electron/runTest.js",
        "lint": "eslint src --ext ts",
        "package": "npm run compile && vsce package --no-dependencies"
    },
    "devDependencies": {
        "@types/glob": "^8.1.0",
        "@types/mocha": "^10.0.0",
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.85.0",
        "@vscode/codicons": "^0.0.45",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.0.0",
        "glob": "^13.0.0",
        "mocha": "^10.7.0",
        "typescript": "^5.3.0"
    },
    "overrides": {
        "serialize-javascript": "^7.0.5"
    }
}
